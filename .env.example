# ── Required: AI provider keys (at least one) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
XAI_API_KEY=...
OPENAI_API_KEY=...          # optional, used for OpenAI-compatible endpoints

# ── Required: your project root ───────────────────────────────────────────────
PF_ECOSPHERE_ROOT=/path/to/your/ecosphere

# ── Optional: external tools ──────────────────────────────────────────────────
GBRAIN_BIN=/path/to/gbrain/bin/gbrain       # L2 memory substrate
CONDA_BIN=/path/to/miniforge3/bin            # for openclaw subprocess
OPENCLAW_GATEWAY_TOKEN=...                   # if using openclaw agent routing
OPENCLAW_BASE_URL=http://127.0.0.1:18789

# ── Optional: file access ─────────────────────────────────────────────────────
FILE_ACCESS_PREFIX=/path/to/your/home        # root for /file slash command
PF_SHARED_DIR=/path/to/your/shared/sync/dir  # iCloud or equivalent EOD sync

# ── Optional: model overrides ─────────────────────────────────────────────────
GE_FLASH_MODEL=gemini-2.0-flash
GE_PRO_MODEL=gemini-2.5-pro-preview-05-06
GR_FAST_MODEL=grok-3-mini-fast
GR_PRO_MODEL=grok-3

# ── Optional: budget ──────────────────────────────────────────────────────────
DAILY_TOKEN_BUDGET=0.50     # max USD/day spend across all automated runners

# ── Optional: search ──────────────────────────────────────────────────────────
TAVILY_API_KEY=...
FIRECRAWL_API_KEY=...
